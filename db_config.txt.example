# 复制本文件为 db_config.txt 并填入真实凭据。
# db_config.txt 已在 .gitignore，不会进仓库。
# 默认路径：<仓库根>/db_config.txt（与本文件同目录）
# 也可通过环境变量 XIAOYU_DB_CONFIG 指定别的位置。

[fish-prod]
host=<MySQL 主机>
port=<端口>
user=<只读账号>
password=<密码>
database=fish-prod
note=原始数据库（mini_* 系列），只读

[fish-test]
host=<MySQL 主机>
port=<端口>
user=<读写账号>
password=<密码>
database=fish-test
note=新基础数据库，标准化产物存储

[cos-ai]
secret_id=<腾讯云 SecretId>
secret_key=<腾讯云 SecretKey>
region=<region，如 ap-beijing>
bucket=ai-1306031257
note=腾讯云 COS 对象存储桶
